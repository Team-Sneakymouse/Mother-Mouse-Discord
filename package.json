{
	"type": "module",
	"packageManager": "bun@1.3.8",
	"engines": {
		"bun": ">=1.3.8",
		"node": ">=24"
	},
	"scripts": {
		"start": "bun src/bot.ts",
		"dev": "docker run --rm -v \"${PWD}:/app\" -w /app -p 80:80 --network db -t --entrypoint sh oven/bun:1.3.8-alpine -c 'apk add youtube-dl ffmpeg && bun install --frozen-lockfile && bun --watch src/bot.ts'",
		"watch": "bun --watch src/bot.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@gitbeaker/node": "^35.8.1",
		"@resvg/resvg-js": "^2.6.2",
		"axios": "^1.16.0",
		"cookie-parser": "^1.4.7",
		"cron": "^3.5.0",
		"discord.js": "^14.26.4",
		"dotenv": "^16.6.1",
		"eventsource": "^2.0.2",
		"express": "^4.22.1",
		"form-data": "^4.0.5",
		"mathjs": "^11.12.0",
		"mime-types": "^2.1.35",
		"pocketbase": "^0.25.2",
		"rss-parser": "^3.13.0",
		"satori": "^0.26.0",
		"socket.io-client": "^4.8.3"
	},
	"devDependencies": {
		"@discordjs/rest": "^2.6.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/eventsource": "^1.1.15",
		"@types/express": "^4.17.25",
		"@types/mime-types": "^2.1.4",
		"@types/node": "^24.12.2",
		"discord-api-types": "^0.30.0",
		"typescript": "^5.9.3"
	}
}
